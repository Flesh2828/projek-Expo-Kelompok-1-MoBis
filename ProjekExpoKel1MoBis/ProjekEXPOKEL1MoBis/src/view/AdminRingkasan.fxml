<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<ScrollPane fx:id="rootRingkasan" fitToWidth="true" style="-fx-background-color: transparent;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdminRingkasanController">
    <VBox fx:id="rootRingkasanBox" prefHeight="1100.0" prefWidth="1000.0" spacing="20.0" style="-fx-background-color: #F7F3EE;">
        <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
            </padding>

        <!-- ===== HEADER ===== -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <VBox spacing="4.0">
                    <Text style="-fx-font-weight: bold; -fx-font-size: 24; -fx-fill: #2E2417;" text="Dashboard Admin" />
                    <Text fx:id="txtSubJudul" style="-fx-font-size: 13; -fx-fill: #9C8E82;" text="Selamat datang kembali, Admin Dewi" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <StackPane>
                    <children>
                        <Label style="-fx-background-color: #FFFFFF; -fx-background-radius: 100; -fx-min-width: 42; -fx-min-height: 42; -fx-max-width: 42; -fx-max-height: 42; -fx-alignment: center; -fx-font-size: 18; -fx-border-color: #EFE7DD; -fx-border-radius: 100;" text="🔔" />
                        <Label style="-fx-background-color: #C35E2A; -fx-text-fill: white; -fx-font-size: 10; -fx-font-weight: bold; -fx-background-radius: 100; -fx-min-width: 17; -fx-min-height: 17; -fx-max-width: 17; -fx-max-height: 17; -fx-alignment: center; -fx-translate-x: 14; -fx-translate-y: -14;" text="3" />
                    </children>
                </StackPane>
            </children>
        </HBox>

        <!-- ===== KARTU STATISTIK ===== -->
        <HBox spacing="15.0">
            <children>

                <!-- Kartu 1: Total Pesanan -->
                <VBox prefWidth="215.0" spacing="10.0" styleClass="card-stat">
                    <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                    <children>
                        <Label styleClass="stat-icon-circle" text="🧺" />
                        <Text fx:id="txtTotalPesanan" styleClass="stat-value" text="7" />
                        <Text styleClass="stat-label" text="Total Pesanan" />
                        <Text styleClass="stat-sub" text="Bulan ini" />
                    </children>
                </VBox>

                <!-- Kartu 2: Pesanan Hari Ini -->
                <VBox prefWidth="215.0" spacing="10.0" styleClass="card-stat">
                    <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                    <children>
                        <Label styleClass="stat-icon-circle" text="🕐" />
                        <Text fx:id="txtPesananHariIni" styleClass="stat-value" text="1" />
                        <Text styleClass="stat-label" text="Pesanan Hari Ini" />
                        <Text fx:id="txtPesananHariIniTanggal" styleClass="stat-sub" text="—" />
                    </children>
                </VBox>

                <!-- Kartu 3: Pendapatan Bulan Ini (highlight) -->
                <VBox prefWidth="215.0" spacing="10.0" styleClass="card-stat, card-stat-highlight">
                    <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                    <children>
                        <Label styleClass="stat-icon-circle-light" text="📈" />
                        <Text fx:id="txtPendapatanBulanIni" styleClass="stat-value-white" text="Rp 0" />
                        <Text styleClass="stat-label-white" text="Pendapatan Bulan Ini" />
                        <Text fx:id="txtTrendPendapatan" styleClass="stat-sub-white" text="—" />
                    </children>
                </VBox>

                <!-- Kartu 4: Menu Aktif -->
                <VBox prefWidth="215.0" spacing="10.0" styleClass="card-stat">
                    <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                    <children>
                        <Label styleClass="stat-icon-circle" text="📖" />
                        <Text fx:id="txtMenuAktif" styleClass="stat-value" text="6" />
                        <Text styleClass="stat-label" text="Menu Aktif" />
                        <Text fx:id="txtMenuAktifSub" styleClass="stat-sub" text="dari 0 menu" />
                    </children>
                </VBox>

            </children>
        </HBox>

        <!-- ===== ALERT KAPASITAS PRODUKSI ===== -->
        <VBox fx:id="boxAlertKapasitas" spacing="8.0" style="-fx-background-color: #FEF9E7; -fx-border-color: #F39C12; -fx-border-radius: 8; -fx-background-radius: 8;">
            <padding><Insets bottom="14.0" left="18.0" right="18.0" top="12.0" /></padding>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Text fx:id="txtKapasitasPersen" style="-fx-font-weight: bold; -fx-fill: #B9770E;" text="⚠️ Kapasitas Produksi: 0% — Mendekati Batas (80%)" />
                <Region HBox.hgrow="ALWAYS" />
                <Text fx:id="txtKapasitasPorsi" style="-fx-font-size: 12; -fx-fill: #7F8C8D;" text="0 / 500 porsi" />
                 </HBox>
            <ProgressBar fx:id="progressKapasitas" prefWidth="900.0" progress="0.0" style="-fx-accent: #F39C12;" />
              </VBox>

        <!-- ===== CARD: PESANAN TERBARU ===== -->
        <VBox spacing="0.0" styleClass="card-pesanan">
            <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Text style="-fx-font-weight: bold; -fx-font-size: 17; -fx-fill: #3A2415;" text="Pesanan Terbaru" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Text fx:id="txtJumlahPesananTerbaru" style="-fx-font-size: 12; -fx-fill: #A79B8E;" text="0 pesanan" />
                    </children>
                    <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                </HBox>

                <TableView fx:id="tablePesananTerbaru" prefHeight="280.0" prefWidth="910.0" styleClass="table-pesanan">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="90.0" text="ID PESANAN" />
                        <TableColumn fx:id="colPelanggan" prefWidth="130.0" text="PELANGGAN" />
                        <TableColumn fx:id="colMenu" prefWidth="150.0" text="MENU" />
                        <TableColumn fx:id="colQty" prefWidth="55.0" text="QTY" />
                        <TableColumn fx:id="colTglKirim" prefWidth="105.0" text="TGL KIRIM" />
                        <TableColumn fx:id="colStatus" prefWidth="120.0" text="STATUS" />
                        <TableColumn fx:id="colPembayaran" prefWidth="115.0" text="PEMBAYARAN" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </VBox>
</ScrollPane>
