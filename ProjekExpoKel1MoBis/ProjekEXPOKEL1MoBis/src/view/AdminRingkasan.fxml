<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.AdminRingkasanController">
    <VBox spacing="20.0">
        <padding>
            <Insets top="25.0" right="25.0" bottom="25.0" left="25.0"/>
        </padding>
        
        <VBox spacing="5.0">
            <Text text="Dashboard Admin" style="-fx-font-weight: bold; -fx-font-size: 24; -fx-fill: #2C3E50;"/>
            <Text text="Selamat datang kembali, Admin Dewi" style="-fx-font-size: 14; -fx-fill: #7F8C8D;"/>
        </VBox>
        
        <HBox spacing="15.0">
            <VBox prefWidth="160.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10;">
                <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
                <Text text="📋 7" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
                <Text text="Total Pesanan" style="-fx-font-size: 11; -fx-fill: #7F8C8D;"/>
            </VBox>
            <VBox prefWidth="160.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10;">
                <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
                <Text text="🕒 1" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
                <Text text="Pesanan Hari Ini" style="-fx-font-size: 11; -fx-fill: #7F8C8D;"/>
            </VBox>
            <VBox prefWidth="160.0" spacing="8.0" style="-fx-background-color: #D35400; -fx-background-radius: 10;">
                <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
                <Text text="Rp 28 Jt" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-fill: white;"/>
                <Text text="Pendapatan Bulan Ini" style="-fx-font-size: 11; -fx-fill: #FADBD8;"/>
            </VBox>
            <VBox prefWidth="160.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10;">
                <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
                <Text text="🍱 6" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
                <Text text="Menu Aktif" style="-fx-font-size: 11; -fx-fill: #7F8C8D;"/>
            </VBox>
        </HBox>
        
        <VBox fx:id="boxAlertKapasitas" spacing="5.0" style="-fx-background-color: #FEF9E7; -fx-border-color: #F39C12; -fx-border-radius: 5; -fx-background-radius: 5;">
            <padding><Insets top="10.0" right="15.0" bottom="10.0" left="15.0"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Text text="⚠️ Kapasitas Produksi: 76% — Mendekati Batas (80%)" style="-fx-font-weight: bold; -fx-fill: #B9770E;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Text text="380 / 500 porsi" style="-fx-font-size: 12; -fx-fill: #7F8C8D;"/>
            </HBox>
            <ProgressBar progress="0.76" prefWidth="700.0" style="-fx-accent: #F39C12;"/>
        </VBox>
        
        <VBox spacing="10.0">
            <Text text="Pesanan Terbaru" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
            <TableView fx:id="tablePesananTerbaru" prefHeight="250.0" prefWidth="700.0">
                <columns>
                    <TableColumn fx:id="colId" text="ID PESANAN" prefWidth="90.0"/>
                    <TableColumn fx:id="colPelanggan" text="PELANGGAN" prefWidth="130.0"/>
                    <TableColumn fx:id="colMenu" text="MENU" prefWidth="150.0"/>
                    <TableColumn fx:id="colQty" text="QTY" prefWidth="60.0"/>
                    <TableColumn fx:id="colTglKirim" text="TGL KIRIM" prefWidth="110.0"/>
                    <TableColumn fx:id="colStatus" text="STATUS" prefWidth="120.0"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>