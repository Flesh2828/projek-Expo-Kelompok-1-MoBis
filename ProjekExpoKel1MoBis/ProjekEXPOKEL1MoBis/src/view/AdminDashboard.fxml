<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="20.0" prefWidth="600.0" prefHeight="400.0" style="-fx-background-color: #fef9e7;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.AdminDashboardController">
    <Text text="PANEL ADMINISTRASI - SINARING" style="-fx-font-weight: bold; -fx-font-size: 22; -fx-fill: #d35400;"/>
    <Label text="Selamat Bekerja, Admin! Pantau operasional dapur dan pesanan masuk." style="-fx-font-size: 14;"/>

    <HBox alignment="CENTER" spacing="10.0">
        <Button text="Kelola Daftar Menu"/>
        <Button text="Update Status Pesanan"/>
    </HBox>

    <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
</VBox>