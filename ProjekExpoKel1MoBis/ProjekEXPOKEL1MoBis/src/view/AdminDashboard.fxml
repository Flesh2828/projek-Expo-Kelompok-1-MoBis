<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="1000.0" prefHeight="650.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.AdminDashboardController">
    
    <left>
        <VBox spacing="15.0" style="-fx-background-color: #D35400;" prefWidth="220.0">
            <padding>
                <Insets top="30.0" right="15.0" bottom="30.0" left="15.0"/>
            </padding>
            
            <VBox spacing="2.0">
                <Text text="SINARING" style="-fx-font-weight: bold; -fx-font-size: 20; -fx-fill: white;"/>
                <Text text="SARI RAHAYU" style="-fx-font-size: 10; -fx-fill: #F5B041; -fx-font-weight: bold;"/>
            </VBox>
            
            <Separator opacity="0.3"/>
            <Text text="MENU UTAMA" style="-fx-font-size: 11; -fx-fill: #FADBD8; -fx-font-weight: bold;"/>
            
            <Button text="📊 Dashboard" onAction="#tampilkanRingkasan" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" prefWidth="200.0"/>
            <Button text="📦 Kelola Pesanan" onAction="#tampilkanKelolaPesanan" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" prefWidth="200.0"/>
            <Button text="📖 Kelola Menu" onAction="#tampilkanKelolaMenu" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" prefWidth="200.0"/>
            
            <Region VBox.vgrow="ALWAYS" />
            
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Text text="👤" style="-fx-font-size: 18; -fx-fill: white;"/>
                <VBox>
                    <Text text="Dewi Ratnasari" style="-fx-font-weight: bold; -fx-fill: white;"/>
                    <Text text="Administrator" style="-fx-font-size: 11; -fx-fill: #FA9644;"/>
                </VBox>
            </HBox>
            
            <Button text="🚪 Keluar" onAction="#handleLogout" style="-fx-background-color: #C0392B; -fx-text-fill: white;" prefWidth="200.0"/>
        </VBox>
    </left>
    
    <center>
        <AnchorPane fx:id="paneKontenAdmin" style="-fx-background-color: #FDFEFE;"/>
    </center>
    
</BorderPane>