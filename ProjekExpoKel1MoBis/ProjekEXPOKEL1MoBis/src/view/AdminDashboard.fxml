<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdminDashboardController">
    
    <left>
        <VBox prefWidth="220.0" spacing="15.0" style="-fx-background-color: #FFFAF0;">
            <padding>
                <Insets bottom="30.0" left="15.0" right="15.0" top="30.0" />
            </padding>
            
            <VBox spacing="2.0">
                <Text style="-fx-font-weight: bold; -fx-font-size: 20; -fx-fill: #C35E2A;" text="SINARING" />
                <Text style="-fx-font-size: 10; -fx-fill: #00000; -fx-font-weight: bold;" text="SARI RAHAYU" />
            </VBox>
            
            <Separator opacity="0.3" />
            <Text style="-fx-font-size: 11; -fx-fill: grey; -fx-font-weight: bold;" text="MENU UTAMA" />
            
            <Button onAction="#tampilkanRingkasan" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #00000; -fx-alignment: center-left;" text="📊 Dashboard" />
            <Button onAction="#tampilkanKelolaPesanan" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #00000; -fx-alignment: center-left;" text="📦 Kelola Pesanan" />
            <Button onAction="#tampilkanKelolaMenu" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #00000; -fx-alignment: center-left;" text="📖 Kelola Menu" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Text style="-fx-font-size: 18; -fx-fill: #C35E2A;" text="👤" />
                <VBox>
                    <Text style="-fx-font-weight: bold; -fx-fill: #C35E2A;" text="Dewi Ratnasari" />
                    <Text style="-fx-font-size: 11; -fx-fill: #C35E2A;" text="Administrator" />
                </VBox>
            </HBox>
            
            <Button onAction="#handleLogout" prefWidth="200.0" style="-fx-background-color: #C35E2A; -fx-text-fill: white;" text="🚪 Keluar" />
        </VBox>
    </left>
    
    <center>
        <AnchorPane fx:id="paneKontenAdmin" style="-fx-background-color: #FFFFF;" />
    </center>
    
</BorderPane>
