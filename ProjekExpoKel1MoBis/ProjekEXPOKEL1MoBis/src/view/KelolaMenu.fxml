<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.text.Font?>

<AnchorPane minHeight="-Infinity" minWidth="-Infinity" prefHeight="860.0" prefWidth="1000.0" style="-fx-background-color: #F7F3EE;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.KelolaMenuController">
   <children>

      <!-- ===== HEADER HALAMAN ===== -->
      <Label layoutX="30.0" layoutY="24.0" text="Kelola Menu" textFill="#4A2E1B">
         <font><Font name="System Bold" size="24.0" /></font>
      </Label>
      <Label layoutX="30.0" layoutY="56.0" text="Daftar menu katering" textFill="#9C8E82" />

      <Button layoutX="822.0" layoutY="26.0" onAction="#handleTambahMenu" prefHeight="34.0" prefWidth="150.0" styleClass="btn-tambah-menu" text="+  Tambah Menu">
         <font><Font size="13.0" /></font>
      </Button>

      <!-- ===== CARD DAFTAR MENU ===== -->
      <AnchorPane layoutX="24.0" layoutY="90.0" prefHeight="740.0" prefWidth="952.0" styleClass="card-pesanan">
         <children>
            <HBox alignment="CENTER_LEFT" layoutX="24.0" layoutY="20.0" prefWidth="904.0" spacing="10.0">
               <children>
                  <Label text="Daftar Menu" textFill="#3A2415">
                     <font><Font name="System Bold" size="17.0" /></font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="lblJumlahMenu" text="0 menu" textFill="#A79B8E">
                     <font><Font size="12.0" /></font>
                  </Label>
               </children>
            </HBox>

            <Region layoutX="24.0" layoutY="56.0" prefHeight="1.0" prefWidth="904.0" style="-fx-background-color: #EFE7DD;" />

            <TableView fx:id="tableMenu" layoutX="24.0" layoutY="68.0" prefHeight="652.0" prefWidth="904.0" styleClass="table-pesanan">
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
               <columns>
                  <TableColumn fx:id="colId" prefWidth="75.0" text="ID" />
                  <TableColumn fx:id="colNama" prefWidth="150.0" text="NAMA MENU" />
                  <TableColumn fx:id="colDeskripsi" prefWidth="300.0" text="DESKRIPSI" />
                  <TableColumn fx:id="colHarga" prefWidth="105.0" text="HARGA" />
                  <TableColumn fx:id="colStatus" prefWidth="100.0" text="STATUS" />
                  <TableColumn fx:id="colAksi" prefWidth="90.0" text="AKSI" />
               </columns>
            </TableView>
         </children>
      </AnchorPane>

   </children>
</AnchorPane>
