<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #F9F6F0;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.KelolaMenuController">
   <children>
      <!-- Header Halaman -->
      <Label layoutX="30.0" layoutY="30.0" text="Kelola Menu" textFill="#101010" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="30.0">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>
      <Label layoutX="30.0" layoutY="70.0" text="Daftar menu aktif dan pengaturan jadwal menu mingguan" textFill="#7A7A7A" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="70.0">
         <font>
            <Font size="14.0" />
         </font>
      </Label>

      <!-- Tombol Tambah Menu Baru -->
      <Button layoutX="650.0" layoutY="45.0" mnemonicParsing="false" onAction="#handleTambahMenu" style="-fx-background-color: #C15C27; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-padding: 8 15 8 15;" text="+ Tambah Menu" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="45.0" />

      <!-- Table View Kelola Menu -->
      <TableView fx:id="tblKelolaMenu" layoutX="30.0" layoutY="130.0" prefHeight="435.0" prefWidth="740.0" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #E0E0E0;" AnchorPane.bottomAnchor="35.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="130.0">
        <columns>
          <TableColumn fx:id="colIdMenu" prefWidth="80.0" text="ID MENU" />
          <TableColumn fx:id="colNamaMenu" prefWidth="150.0" text="NAMA MENU" />
          <TableColumn fx:id="colDeskripsi" prefWidth="250.0" text="DESKRIPSI" />
          <TableColumn fx:id="colHarga" prefWidth="120.0" text="HARGA" />
          <TableColumn fx:id="colStatusMenu" prefWidth="110.0" text="STATUS" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</AnchorPane>
