<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="400.0" prefHeight="300.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.RegistrasiController">
    
    <Text text="DAFTAR AKUN PELANGGAN BARU" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
    
    <TextField fx:id="txtRegUsername" promptText="Buat Username Baru" maxWidth="250.0"/>
    <PasswordField fx:id="txtRegPassword" promptText="Buat Password" maxWidth="250.0"/>
    
    <Button text="Daftar Sekarang" onAction="#handleRegistrasi" prefWidth="150.0"/>
    <Label fx:id="lblPesanStatus" text="" textFill="GREEN"/>
    
    <Hyperlink text="Sudah punya akun? Kembali ke Login" onAction="#keHalamanLogin"/>
</VBox>