<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.OwnerPiutangController">
   <padding>
      <Insets bottom="35.0" left="35.0" right="35.0" top="35.0" />
   </padding>
   <children>
      <VBox spacing="5.0">
         <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2B1B15;" text="Piutang Pelanggan" />
         <Label style="-fx-font-size: 14; -fx-text-fill: #8A7A75;" text="Daftar tagihan belum lunas dari seluruh pelanggan" />
      </VBox>

      <HBox prefHeight="140.0" spacing="20.0">
         <VBox style="-fx-background-color: #FFFAF0; -fx-background-radius: 20; -fx-padding: 20;" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #2B1B15; -fx-padding: 12 0 2 0;" text="Rp 12.920.000" />
            <Label style="-fx-font-size: 13; -fx-text-fill: #8A7A75;" text="Total Piutang" />
         </VBox>

         <VBox style="-fx-background-color: #FFFAF0; -fx-background-radius: 20; -fx-padding: 20;" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #2B1B15; -fx-padding: 12 0 2 0;" text="2" />
            <Label style="-fx-font-size: 13; -fx-text-fill: #6E5E59; -fx-font-weight: bold;" text="Melewati Jatuh Tempo" />
            <Label style="-fx-font-size: 11; -fx-text-fill: #8A7A75;" text="&gt; 7 hari" />
         </VBox>

         <VBox style="-fx-background-color: #FFFAF0; -fx-background-radius: 20; -fx-padding: 20;" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #2B1B15; -fx-padding: 12 0 2 0;" text="1" />
            <Label style="-fx-font-size: 13; -fx-text-fill: #6E5E59; -fx-font-weight: bold;" text="Akan Jatuh Tempo" />
            <Label style="-fx-font-size: 11; -fx-text-fill: #8A7A75;" text="dalam 7 hari ke depan" />
         </VBox>
      </HBox>

      <VBox style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25;">
         <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 15 0;">
            <Label style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2B1B15;" text="Daftar Piutang" HBox.hgrow="ALWAYS" />
            <Label alignment="CENTER_RIGHT" style="-fx-font-size: 12; -fx-text-fill: #8A7A75;" text="5 tagihan" />
         </HBox>

         <HBox spacing="15.0" style="-fx-padding: 0 0 15 5;">
            <HBox alignment="CENTER" spacing="5.0">
               <Label style="-fx-text-fill: #E9B4B4; -fx-font-size: 14;" text="●" />
               <Label style="-fx-font-size: 12; -fx-text-fill: #8A7A75;" text="Lewat &gt;7 hari" />
            </HBox>
            <HBox alignment="CENTER" spacing="5.0">
               <Label style="-fx-text-fill: #F5E3A1; -fx-font-size: 14;" text="●" />
               <Label style="-fx-font-size: 12; -fx-text-fill: #8A7A75;" text="Jatuh tempo 1-7 hari" />
            </HBox>
            <HBox alignment="CENTER" spacing="5.0">
               <Label style="-fx-text-fill: #A0E7CD; -fx-font-size: 14;" text="●" />
               <Label style="-fx-font-size: 12; -fx-text-fill: #8A7A75;" text="Belum jatuh tempo" />
            </HBox>
         </HBox>

         <TableView fx:id="tablePiutang" prefHeight="280.0">
            <columns>
               <TableColumn fx:id="colPelanggan" prefWidth="180.0" text="PELANGGAN" />
               <TableColumn fx:id="colIdPesanan" prefWidth="110.0" text="ID PESANAN" />
               <TableColumn fx:id="colTotalTagihan" prefWidth="140.0" text="TOTAL TAGIHAN" />
               <TableColumn fx:id="colDpDibayar" prefWidth="130.0" text="DP DIBAYAR" />
               <TableColumn fx:id="colSisaTagihan" prefWidth="140.0" text="SISA TAGIHAN" />
               <TableColumn fx:id="colJatuhTempo" prefWidth="130.0" text="JATUH TEMPO" />
               <TableColumn fx:id="colStatus" prefWidth="130.0" text="STATUS" />
            </columns>
         </TableView>
      </VBox>
   </children>
</VBox>