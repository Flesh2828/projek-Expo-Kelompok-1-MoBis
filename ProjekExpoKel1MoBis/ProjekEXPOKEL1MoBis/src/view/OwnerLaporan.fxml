<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="1200.0" prefWidth="1500.0" spacing="25.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.OwnerLaporanController">
   <padding>
      <Insets bottom="35.0" left="35.0" right="35.0" top="35.0" />
   </padding>
   <children>
      <VBox spacing="5.0">
         <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2B1B15;" text="Laporan Keuangan" />
         <Label style="-fx-font-size: 14; -fx-text-fill: #8A7A75;" text="Pendapatan, pengeluaran, dan laba bersih bulanan" />
      </VBox>

      <HBox prefHeight="320.0" spacing="20.0">
         <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20;" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 25; -fx-font-weight: bold; -fx-text-fill: #2B1B15;" text="Pendapatan vs Pengeluaran" />
            <Label style="-fx-font-size: 18; -fx-text-fill: #8A7A75; -fx-padding: 0 0 10 0;" text="Perbandingan bulanan (dalam Rupiah)" />
            <BarChart fx:id="barChartLaporan" alternativeRowFillVisible="false" legendSide="BOTTOM" prefHeight="240.0" verticalGridLinesVisible="false">
               <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
               <yAxis><NumberAxis side="LEFT" /></yAxis>
            </BarChart>
         </VBox>

         <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20;" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 25; -fx-font-weight: bold; -fx-text-fill: #2B1B15;" text="Tren Laba Bersih" />
            <Label style="-fx-font-size: 18; -fx-text-fill: #8A7A75; -fx-padding: 0 0 10 0;" text="Perkembangan laba per bulan" />
            <LineChart fx:id="lineChartLaporan" createSymbols="true" legendSide="BOTTOM" prefHeight="240.0">
               <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
               <yAxis><NumberAxis side="LEFT" /></yAxis>
            </LineChart>
         </VBox>
      </HBox>

      <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20;">
         <Label style="-fx-font-size: 25; -fx-font-weight: bold; -fx-text-fill: #2B1B15; -fx-padding: 0 0 15 0;" text="Ringkasan Bulanan" />
         <TableView fx:id="tableRingkasan" prefHeight="200.0" style="-fx-background-radius: 8;">
            <columns>
               <TableColumn prefWidth="150.0" text="BULAN" />
               <TableColumn prefWidth="200.0" text="PENDAPATAN" />
               <TableColumn prefWidth="200.0" text="PENGELUARAN" />
               <TableColumn prefWidth="200.0" text="LABA BERSIH" />
               <TableColumn prefWidth="150.0" text="MARGIN" />
            </columns>
         </TableView>
      </VBox>
   </children>
</VBox>
