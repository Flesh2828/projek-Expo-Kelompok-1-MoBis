<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="1200.0" prefWidth="1500.0" style="-fx-background-color: ffffff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.KelolaPesananController">
   <children>
      <Label layoutX="30.0" layoutY="20.0" text="Kelola Pesanan" textFill="#4A2E1B"><font><Font name="System Bold" size="24.0" /></font></Label>
      <Label layoutX="30.0" layoutY="50.0" text="Pembaruan status dan monitoring pesanan masuk" textFill="#888" />
      
      <HBox layoutX="30.0" layoutY="90.0" spacing="10.0" />

      <TableView fx:id="tableKelolaPesanan" layoutX="30.0" layoutY="140.0" prefHeight="613.0" prefWidth="1285.0">
        <columns>
          <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
          <TableColumn fx:id="colPelanggan" prefWidth="120.0" text="PELANGGAN" />
          <TableColumn fx:id="colMenu" prefWidth="140.0" text="MENU" />
          <TableColumn fx:id="colQty" prefWidth="50.0" text="QTY" />
          <TableColumn fx:id="colTglKirim" prefWidth="100.0" text="TGL KIRIM" />
          <TableColumn fx:id="colAlamat" prefWidth="130.0" text="ALAMAT" />
          <TableColumn fx:id="colStatus" prefWidth="90.0" text="STATUS" />
          <TableColumn fx:id="colPembayaran" prefWidth="80.0" text="PEMBAYARAN" />
        </columns>
      </TableView>

      <HBox layoutX="30.0" layoutY="535.0" spacing="15.0" />
      <Text layoutX="30.0" layoutY="123.0" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-font-size: 20; -fx-font-style: amiri;" text="Semua data" />
      <Button layoutX="1101.0" layoutY="780.0" onAction="#handleVerifikasiPembayaran" prefHeight="25.0" prefWidth="214.0" style="-fx-background-color: #32CD32; -fx-text-fill: white; -fx-font-weight: bold;" text="✔ Verifikasi Pembayaran">
         <font>
            <Font size="15.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
