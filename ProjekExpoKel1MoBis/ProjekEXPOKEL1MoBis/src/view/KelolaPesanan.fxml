<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane minHeight="-Infinity" minWidth="-Infinity" prefHeight="820.0" prefWidth="1000.0" style="-fx-background-color: #F7F3EE;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.KelolaPesananController">
   <children>

      <!-- ===== HEADER HALAMAN ===== -->
      <Label layoutX="30.0" layoutY="24.0" text="Kelola Pesanan" textFill="#4A2E1B">
         <font><Font name="System Bold" size="24.0" /></font>
      </Label>
      <Label layoutX="30.0" layoutY="56.0" text="Pembaruan status dan monitoring pesanan masuk" textFill="#9C8E82" />

      <!-- ===== CARD PUTIH ===== -->
      <AnchorPane fx:id="cardContainer" layoutX="24.0" layoutY="94.0" prefHeight="680.0" prefWidth="952.0" styleClass="card-pesanan">
         <children>

            <!-- Baris judul kartu + jumlah pesanan -->
            <HBox alignment="CENTER_LEFT" layoutX="24.0" layoutY="20.0" prefWidth="904.0" spacing="10.0">
               <children>
                  <Label text="Daftar Pesanan" textFill="#3A2415">
                     <font><Font name="System Bold" size="17.0" /></font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="lblJumlahPesanan" text="0 pesanan" textFill="#A79B8E">
                     <font><Font size="12.0" /></font>
                  </Label>
               </children>
            </HBox>

            <!-- Garis pemisah tipis -->
            <Region layoutX="24.0" layoutY="56.0" prefHeight="1.0" prefWidth="904.0" style="-fx-background-color: #EFE7DD;" />

            <!-- Tabel pesanan -->
            <TableView fx:id="tableKelolaPesanan" layoutX="24.0" layoutY="68.0" prefHeight="592.0" prefWidth="904.0" styleClass="table-pesanan">
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
               <columns>
                  <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
                  <TableColumn fx:id="colPelanggan" prefWidth="120.0" text="PELANGGAN" />
                  <TableColumn fx:id="colMenu" prefWidth="140.0" text="MENU" />
                  <TableColumn fx:id="colQty" prefWidth="55.0" text="QTY" />
                  <TableColumn fx:id="colTglKirim" prefWidth="95.0" text="TGL KIRIM" />
                  <TableColumn fx:id="colAlamat" prefWidth="140.0" text="ALAMAT" />
                  <TableColumn fx:id="colStatus" prefWidth="120.0" text="STATUS" />
                  <TableColumn fx:id="colPembayaran" prefWidth="115.0" text="PEMBAYARAN" />
               </columns>
            </TableView>

         </children>
         <padding>
            <Insets bottom="16.0" left="0.0" right="0.0" top="0.0" />
         </padding>
      </AnchorPane>

      <!-- ===== TOMBOL AKSI ===== -->
      <Button layoutX="738.0" layoutY="786.0" onAction="#handleVerifikasiPembayaran" prefHeight="34.0" prefWidth="238.0" styleClass="btn-verifikasi" text="✔  Verifikasi Pembayaran">
         <font>
            <Font size="14.0" />
         </font>
      </Button>

   </children>
</AnchorPane>
