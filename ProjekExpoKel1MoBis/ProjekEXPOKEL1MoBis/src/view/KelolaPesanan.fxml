<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane minHeight="-Infinity" minWidth="-Infinity" prefHeight="850.0" prefWidth="1000.0" style="-fx-background-color: #F7F3EE;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.KelolaPesananController">
   <children>

      <!-- ===== HEADER HALAMAN ===== -->
      <Label layoutX="30.0" layoutY="24.0" text="Kelola Pesanan" textFill="#4A2E1B">
         <font><Font name="System Bold" size="24.0" /></font>
      </Label>
      <Label layoutX="30.0" layoutY="56.0" text="Pembaruan status dan monitoring pesanan masuk" textFill="#9C8E82" />

      <!-- ===== BAGIAN ATAS: CARD PUTIH (TABEL PESANAN) ===== -->
      <AnchorPane fx:id="cardContainer" layoutX="24.0" layoutY="94.0" prefHeight="420.0" prefWidth="952.0" styleClass="card-pesanan">
         <children>

            <!-- Baris judul kartu + tombol aksi + jumlah pesanan -->
            <HBox alignment="CENTER_LEFT" layoutX="24.0" layoutY="20.0" prefWidth="904.0" spacing="14.0">
               <children>
                  <Label text="Daftar Pesanan" textFill="#3A2415">
                     <font><Font name="System Bold" size="17.0" /></font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#handleTandaiSelesai" prefHeight="30.0" prefWidth="170.0" styleClass="btn-selesai" text="🏁  Tandai Selesai">
                     <font>
                        <Font size="12.0" />
                     </font>
                  </Button>
                  <Button onAction="#handleVerifikasiPembayaran" prefHeight="30.0" prefWidth="200.0" styleClass="btn-verifikasi" text="✔  Verifikasi Pembayaran">
                     <font>
                        <Font size="12.0" />
                     </font>
                  </Button>
                  <Label fx:id="lblJumlahPesanan" text="0 pesanan" textFill="#A79B8E">
                     <font><Font size="12.0" /></font>
                  </Label>
               </children>
            </HBox>

            <!-- Garis pemisah tipis -->
            <Region layoutX="24.0" layoutY="56.0" prefHeight="1.0" prefWidth="904.0" style="-fx-background-color: #EFE7DD;" />

            <!-- Tabel pesanan -->
            <TableView fx:id="tableKelolaPesanan" layoutX="24.0" layoutY="68.0" prefHeight="332.0" prefWidth="904.0" styleClass="table-pesanan">
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
               <columns>
                  <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
                  <TableColumn fx:id="colPelanggan" prefWidth="120.0" text="PELANGGAN" />
                  <TableColumn fx:id="colMenu" prefWidth="140.0" text="MENU" />
                  <TableColumn fx:id="colQty" prefWidth="55.0" text="QTY" />
                  <TableColumn fx:id="colTglKirim" prefWidth="95.0" text="TGL KIRIM" />
                  <TableColumn fx:id="colAlamat" prefWidth="140.0" text="ALAMAT" />
                  <TableColumn fx:id="colStatus" prefWidth="120.0" text="STATUS" />
                  <TableColumn fx:id="colPembayaran" prefWidth="115.0" text="PEMBAYARAN" />
               </columns>
            </TableView>

         </children>
         <padding>
            <Insets bottom="16.0" left="0.0" right="0.0" top="0.0" />
         </padding>
      </AnchorPane>

      <!-- ===== BAGIAN BAWAH: CARD PUTIH (ANTREAN PESANAN / QUEUE) ===== -->
      <AnchorPane fx:id="cardAntrean" layoutX="24.0" layoutY="530.0" prefHeight="290.0" prefWidth="952.0" styleClass="card-pesanan">
         <children>

            <!-- Baris judul kartu antrean + jumlah + tombol aksi -->
            <HBox alignment="CENTER_LEFT" layoutX="24.0" layoutY="20.0" prefWidth="904.0" spacing="14.0">
               <children>
                  <VBox spacing="2.0">
                     <children>
                        <Label text="Antrean Pesanan" textFill="#3A2415">
                           <font><Font name="System Bold" size="17.0" /></font>
                        </Label>
                        <Label text="Berstatus Dikonfirmasi, urut FIFO — paling kiri = paling awal masuk (Head)" textFill="#A79B8E">
                           <font><Font size="11.0" /></font>
                        </Label>
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="lblJumlahAntrean" text="0 dalam antrean" textFill="#A79B8E">
                     <font><Font size="12.0" /></font>
                  </Label>
                  <Button fx:id="btnSelesaikanAntrean" onAction="#handleSelesaikanAntreanTerdepan" prefHeight="36.0" prefWidth="260.0" styleClass="btn-antrean" text="🍳  Selesaikan Antrean Terdepan">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Button>
               </children>
            </HBox>

            <!-- Garis pemisah tipis -->
            <Region layoutX="24.0" layoutY="68.0" prefHeight="1.0" prefWidth="904.0" style="-fx-background-color: #EFE7DD;" />

            <!-- Daftar antrean: strip horizontal supaya seluruh antrean terlihat sekaligus -->
            <ListView fx:id="listAntrean" layoutX="24.0" layoutY="80.0" prefHeight="182.0" prefWidth="904.0" styleClass="list-antrean" />

         </children>
         <padding>
            <Insets bottom="16.0" left="0.0" right="0.0" top="0.0" />
         </padding>
      </AnchorPane>

   </children>
</AnchorPane>
