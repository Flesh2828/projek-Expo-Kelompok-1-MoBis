<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #F9F6F0;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.KelolaPesananController">
   <children>
      <!-- Header Halaman -->
      <Label layoutX="30.0" layoutY="30.0" text="Kelola Pesanan" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="30.0">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>
      <Label layoutX="30.0" layoutY="70.0" text="Pembaruan status dan monitoring pesanan masuk" textFill="#7A7A7A" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="70.0">
         <font>
            <Font size="14.0" />
         </font>
      </Label>

      <!-- Filter Menu Mini Button -->
      <HBox layoutX="30.0" layoutY="115.0" spacing="10.0" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="115.0">
         <children>
            <Button style="-fx-background-color: #C15C27; -fx-text-fill: white; -fx-background-radius: 15; -fx-padding: 5 15 5 15;" text="Semua" />
            <Button style="-fx-background-color: white; -fx-text-fill: #7A7A7A; -fx-border-color: #E0E0E0; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 5 15 5 15;" text="Dikonfirmasi" />
            <Button style="-fx-background-color: white; -fx-text-fill: #7A7A7A; -fx-border-color: #E0E0E0; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 5 15 5 15;" text="Dimasak" />
            <Button style="-fx-background-color: white; -fx-text-fill: #7A7A7A; -fx-border-color: #E0E0E0; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 5 15 5 15;" text="Dikirim" />
         </children>
      </HBox>

      <!-- Table View Utama -->
      <TableView fx:id="tblDaftarPesanan" layoutX="30.0" layoutY="165.0" prefHeight="400.0" prefWidth="740.0" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #E0E0E0;" AnchorPane.bottomAnchor="35.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="165.0">
        <columns>
          <TableColumn fx:id="colId" prefWidth="85.0" text="ID" />
          <TableColumn fx:id="colPelanggan" prefWidth="120.0" text="PELANGGAN" />
          <TableColumn fx:id="colMenu" prefWidth="130.0" text="MENU" />
          <TableColumn fx:id="colQty" prefWidth="60.0" text="QTY" />
          <TableColumn fx:id="colTglKirim" prefWidth="100.0" text="TGL KIRIM" />
          <TableColumn fx:id="colAlamat" prefWidth="110.0" text="ALAMAT" />
          <TableColumn fx:id="colStatus" prefWidth="110.0" text="STATUS" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</AnchorPane>
