<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefWidth="710.0" prefHeight="540.0" style="-fx-background-color: #FDFEFE;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.BuatPesananController">
    <children>
        <Text text="Formulir Pesanan" layoutX="30.0" layoutY="50.0" style="-fx-font-weight: bold; -fx-font-size: 24; -fx-fill: #2C3E50;"/>
        <Text text="Isi detail pesanan Anda di bawah ini" layoutX="30.0" layoutY="75.0" style="-fx-font-size: 14; -fx-fill: #7F8C8D;"/>
        
        <VBox spacing="15.0" layoutX="30.0" layoutY="100.0" prefWidth="650.0" style="-fx-background-color: #FAFAFA; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10;">
            <padding><Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/></padding>
            
            <Label text="Pilih Menu" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtPilihanMenu" editable="false" promptText="Nama menu pilihan" style="-fx-background-color: #EEEEEE;"/>
            
            <HBox spacing="20.0">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Jumlah Porsi" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtJumlahPorsi" text="1"/>
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Tanggal Pengiriman" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtTanggalKirim" promptText="Contoh: 10 Jul 2026"/>
                </VBox>
            </HBox>
            
            <Label text="Alamat Pengiriman" style="-fx-font-weight: bold;"/>
            <TextArea fx:id="txtAlamatKirim" prefHeight="80.0" promptText="Jl. Contoh No. 1, Kelurahan, Kecamatan, Kota"/>
            
            <Label text="Catatan Khusus (Opsional)" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtCatatan" promptText="Contoh: tidak pedas, alergi kacang, dll."/>
            
            <Button text="Kirim Pesanan" onAction="#handleKirimPesanan" style="-fx-background-color: #D35400; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="610.0"/>
            <Label fx:id="lblStatusOrder" text="" style="-fx-font-size: 13;"/>
        </VBox>
    </children>
</AnchorPane>