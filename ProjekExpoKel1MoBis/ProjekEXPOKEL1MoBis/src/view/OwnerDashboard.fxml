<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="700.0" spacing="25.0" 
      style="-fx-background-color: linear-gradient(to bottom, #FFF3E3, #F7E5D0);" 
      xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="controller.OwnerDashboardController">
    
    <padding>
        <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
    </padding>

    <!-- Header Section -->
    <VBox alignment="CENTER" spacing="5.0">
        <Text style="-fx-font-weight: bold; -fx-font-size: 26; -fx-fill: #4A2E1B; -fx-font-family: 'Arial';" text="PANEL OWNER" />
        <Text style="-fx-font-weight: bold; -fx-font-size: 14; -fx-fill: #BC5426; -fx-font-family: 'Arial';" text="SINARING - Sistem Informasi Usaha Katering" />
    </VBox>

    <!-- Main Card Content -->
    <VBox alignment="CENTER" maxWidth="500.0" spacing="20.0" 
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
        
        <padding>
            <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
        </padding>

        <Label style="-fx-font-size: 14; -fx-text-fill: #5D4037; -fx-text-alignment: center;" 
               text="Selamat Datang, Owner! Berikut ringkasan performa finansial bisnis Anda." 
               wrapText="true" />
        
        <!-- Action Buttons -->
        <HBox alignment="CENTER" spacing="15.0">
            <Button prefHeight="40.0" prefWidth="180.0" 
                    style="-fx-background-color: #BC5426; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" 
                    text="Lihat Grafik Keuangan" />
            
            <Button prefHeight="40.0" prefWidth="180.0" 
                    style="-fx-background-color: #BC5426; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" 
                    text="Pantau Piutang" />
        </HBox>
    </VBox>

    <!-- Footer / Logout Button -->
    <Button onAction="#handleLogout" prefHeight="35.0" prefWidth="120.0"
            style="-fx-background-color: transparent; -fx-text-fill: #E74C3C; -fx-font-weight: bold; -fx-border-color: #E74C3C; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" 
            text="Keluar / Logout" />
            
    <Text style="-fx-font-size: 11; -fx-fill: #8D6E63;" text="© 2026 Sari Rahayu Catering - SINARING v1.0" />

</VBox>