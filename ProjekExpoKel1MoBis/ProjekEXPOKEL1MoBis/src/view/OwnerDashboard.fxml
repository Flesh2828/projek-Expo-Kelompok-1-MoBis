                           </children>
                        </VBox>
                        <!-- Pill Badge Laporan Keuangan -->
                        <HBox alignment="CENTER" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 8 18 8 18; -fx-border-color: #E2DDD7; -fx-border-radius: 20;">
                           <children>
                              <Label style="-fx-text-fill: #B54D22; -fx-font-weight: bold;" text="📊" />
                              <Label style="-fx-text-fill: #B54D22; -fx-font-weight: bold; -fx-font-size: 13;" text="Laporan Keuangan" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>

                  <!-- 4 KARTU RINGKASAN KEUANGAN -->
                  <HBox spacing="15.0" prefHeight="150.0">
                     <children>
                        <!-- Kartu 1: Pendapatan (Terracotta) -->
                        <VBox prefWidth="230.0" style="-fx-background-color: #B54D22; -fx-background-radius: 20; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                           <children>
                              <VBox alignment="CENTER" prefHeight="36.0" prefWidth="36.0" maxWidth="36.0" style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 10;">
                                 <children>
                                    <Label style="-fx-text-fill: white; -fx-font-size: 16;" text="📈" />
                                 </children>
                              </VBox>
                              <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 15 0 2 0;" text="Rp 138,5 Jt" />
                              <Label style="-fx-font-size: 13; -fx-text-fill: #E6BCAB;" text="Pendapatan (6 Bln)" />
                           </children>
                        </VBox>

                        <!-- Kartu 2: Pengeluaran (Putih) -->
                        <VBox prefWidth="230.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
                           <children>
                              <VBox alignment="CENTER" prefHeight="36.0" prefWidth="36.0" maxWidth="36.0" style="-fx-background-color: #FAF5EF; -fx-background-radius: 10;">
                                 <children>
                                    <Label style="-fx-text-fill: #B54D22; -fx-font-size: 16;" text="📦" />
                                 </children>
                              </VBox>
                              <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #2B1B15; -fx-padding: 15 0 2 0;" text="Rp 88 Jt" />
                              <Label style="-fx-font-size: 13; -fx-text-fill: #6E5E59; -fx-font-weight: bold;" text="Pengeluaran (6 Bln)" />
                              <Label style="-fx-font-size: 11; -fx-text-fill: #8A7A75;" text="Bahan baku &amp; operasional" />
                           </children>
                        </VBox>

                        <!-- Kartu 3: Laba Bersih (Putih) -->
                        <VBox prefWidth="230.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
                           <children>
                              <VBox alignment="CENTER" prefHeight="36.0" prefWidth="36.0" maxWidth="36.0" style="-fx-background-color: #FAF5EF; -fx-background-radius: 10;">
                                 <children>
                                    <Label style="-fx-text-fill: #B54D22; -fx-font-size: 16;" text="👛" />
                                 </children>
                              </VBox>
                              <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #2B1B15; -fx-padding: 15 0 2 0;" text="Rp 50,5 Jt" />
                              <Label style="-fx-font-size: 13; -fx-text-fill: #6E5E59; -fx-font-weight: bold;" text="Laba Bersih (6 Bln)" />
                              <Label style="-fx-font-size: 11; -fx-text-fill: #8A7A75;" text="Margin rata-rata 36%" />
                           </children>
                        </VBox>

                        <!-- Kartu 4: Total Piutang (Putih) -->
                        <VBox prefWidth="230.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
                           <children>
                              <VBox alignment="CENTER" prefHeight="36.0" prefWidth="36.0" maxWidth="36.0" style="-fx-background-color: #FAF5EF; -fx-background-radius: 10;">
                                 <children>
                                    <Label style="-fx-text-fill: #B54D22; -fx-font-size: 16;" text="⚠️" />
                                 </children>
                              </VBox>
                              <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #2B1B15; -fx-padding: 15 0 2 0;" text="Rp 12.920.000" />
                              <Label style="-fx-font-size: 13; -fx-text-fill: #6E5E59; -fx-font-weight: bold;" text="Total Piutang" />
                              <Label style="-fx-font-size: 11; -fx-text-fill: #B54D22; -fx-font-weight: bold;" text="2 tagihan lewat jatuh tempo" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <!-- GRAFIK TREN LABA BERSIH -->
                  <VBox style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
                     <children>
                        <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2B1B15;" text="Tren Laba Bersih" />
                        <Label style="-fx-font-size: 13; -fx-text-fill: #8A7A75; -fx-padding: 0 0 15 0;" text="Feb - Jul 2026" />
                        
                        <LineChart fx:id="chartDashboard" alternativeRowFillVisible="false" createSymbols="true" horizontalGridLinesVisible="true" legendVisible="false" prefHeight="320.0" verticalGridLinesVisible="false">
                           <xAxis>
                              <CategoryAxis side="BOTTOM" />
                           </xAxis>
                           <yAxis>
                              <NumberAxis side="LEFT" />
                           </yAxis>
                        </LineChart>
                     </children>
                  </VBox>

               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</HBox>