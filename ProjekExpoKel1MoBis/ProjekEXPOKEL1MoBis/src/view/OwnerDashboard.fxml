<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox fx:id="mainRoot" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #FAF5EF;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.OwnerDashboardController">
   <children>
      <!-- ==================== SIDEBAR OWNER (LEFT) ==================== -->
      <VBox prefHeight="720.0" prefWidth="260.0" style="-fx-background-color: #B54D22;" spacing="0.0">
         <padding>
            <Insets top="30.0" right="20.0" bottom="30.0" left="20.0" />
         </padding>
         <children>
            <!-- Header Logo & Nama Bisnis -->
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <VBox alignment="CENTER" prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 12;">
                     <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="🍳" />
                     </children>
                  </VBox>
                  <VBox spacing="1.0">
                     <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" text="SINARING" />
                        <Label style="-fx-text-fill: #F0D0C0; -fx-font-size: 10; -fx-font-weight: bold;" text="SARI RAHAYU" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <Label style="-fx-text-fill: #E6BCAB; -fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 40 0 10 5;" text="MENU UTAMA" />
            
            <!-- Navigation Links -->
            <VBox spacing="8.0" VBox.vgrow="ALWAYS">
               <children>
                  <Button fx:id="btnDashboard" alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="45.0" prefWidth="220.0" style="-fx-background-color: rgba(255, 255, 255, 0.15); -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 0 0 0 15;" text=" 🎛️   Dashboard" />
                  <Button fx:id="btnLaporan" alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="45.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-text-fill: #F0D0C0; -fx-font-size: 14; -fx-padding: 0 0 0 15;" text=" 📊   Laporan Keuangan" />
                  <Button fx:id="btnPiutang" alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="45.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-text-fill: #F0D0C0; -fx-font-size: 14; -fx-padding: 0 0 0 15;" text=" 💼   Piutang" />
               </children>
            </VBox>
            
            <!-- Footer User Info & Keluar -->
            <VBox spacing="15.0">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-padding: 10 0 10 0; -fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 1 0 0 0;">
                     <children>
                        <VBox alignment="CENTER" prefHeight="38.0" prefWidth="38.0" style="-fx-background-color: #E6BCAB; -fx-background-radius: 19;">
                           <children>
                              <Label style="-fx-text-fill: #B54D22; -fx-font-weight: bold; -fx-font-size: 14;" text="S" />
                           </children>
                        </VBox>
                        <VBox>
                           <children>
                              <Label style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;" text="Sari Rahayu" />
                              <Label style="-fx-text-fill: #E6BCAB; -fx-font-size: 11;" text="Pemilik Usaha" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <Button alignment="BASELINE_LEFT" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #F0D0C0; -fx-font-size: 14; -fx-padding: 5 0 0 5;" text="🚪  Keluar" />
               </children>
            </VBox>
         </children>
      </VBox>

      <!-- ==================== CONTENT AREA (RIGHT) ==================== -->
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-radius: 0; -fx-border-color: transparent;" HBox.hgrow="ALWAYS">
         <content>
            <VBox spacing="25.0" style="-fx-background-color: #FAF5EF;">
               <padding>
                  <Insets top="35.0" right="35.0" bottom="35.0" left="35.0" />
               </padding>
               <children>
                  
                  <!-- Top Title & Badge Filter Row -->
                  <HBox alignment="CENTER_LEFT" spacing="20.0">
                     <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2B1B15; -fx-font-family: 'Segoe UI';" text="Dashboard Pemilik" />
