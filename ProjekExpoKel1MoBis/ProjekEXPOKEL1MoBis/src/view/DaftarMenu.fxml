<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.DaftarMenuController" prefWidth="730.0" prefHeight="600.0" style="-fx-background-color: #FDFEFE;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <VBox spacing="15.0" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">

        <Text text="Daftar Menu" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-fill: #2E7D32;" />
        <Text text="Pilih menu favorit Anda dari dapur Sari Rahayu" style="-fx-font-size: 14; -fx-fill: #666666;" />

        <Separator />

        <GridPane hgap="20" vgap="20">
            <columnConstraints>
                <ColumnConstraints percentWidth="50" />
                <ColumnConstraints percentWidth="50" />
            </columnConstraints>

            <!-- Menu 1: Nasi Box Spesial -->
            <VBox spacing="5.0" GridPane.columnIndex="0" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Text text="🍱 Nasi Box Spesial" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-fill: #2E7D32;" />
                <Text text="Nasi putih, ayam goreng, tempe, sayur, sambal" style="-fx-font-size: 12; -fx-fill: #666666;" />
                <Text text="Rp 25.000/porsi" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-fill: #D35400;" />
                <Button text="Pesan" onAction="#handlePesanNasiBox" style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="150.0" />
            </VBox>

            <!-- Menu 2: Nasi Gudeg Komplit -->
            <VBox spacing="5.0" GridPane.columnIndex="1" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Text text="🍲 Nasi Gudeg Komplit" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-fill: #2E7D32;" />
                <Text text="Nasi gudeg, ayam, krecek, telur bacem" style="-fx-font-size: 12; -fx-fill: #666666;" />
                <Text text="Rp 28.000/porsi" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-fill: #D35400;" />
                <Button text="Pesan" onAction="#handlePesanNasiGudeg" style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="150.0" />
            </VBox>

            <!-- Menu 3: Nasi Padang -->
            <VBox spacing="5.0" GridPane.columnIndex="0" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Text text="🍛 Nasi Padang" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-fill: #2E7D32;" />
                <Text text="Nasi dengan lauk pilihan rendang dan gulai" style="-fx-font-size: 12; -fx-fill: #666666;" />
                <Text text="Rp 30.000/porsi" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-fill: #D35400;" />
                <Button text="Pesan" onAction="#handlePesanNasiPadang" style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="150.0" />
            </VBox>

            <!-- Menu 4: Ayam Bakar Komplit -->
            <VBox spacing="5.0" GridPane.columnIndex="1" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Text text="🍗 Ayam Bakar Komplit" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-fill: #2E7D32;" />
                <Text text="Ayam bakar, nasi, lalapan, sambal terasi" style="-fx-font-size: 12; -fx-fill: #666666;" />
                <Text text="Rp 32.000/porsi" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-fill: #D35400;" />
                <Button text="Pesan" onAction="#handlePesanAyamBakar" style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="150.0" />
            </VBox>

            <!-- Menu 5: Mie Goreng Spesial -->
            <VBox spacing="5.0" GridPane.columnIndex="0" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Text text="🍜 Mie Goreng Spesial" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-fill: #2E7D32;" />
                <Text text="Mie goreng dengan telur, udang, sayuran segar" style="-fx-font-size: 12; -fx-fill: #666666;" />
                <Text text="Rp 20.000/porsi" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-fill: #D35400;" />
                <Button text="Pesan" onAction="#handlePesanMieGoreng" style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="150.0" />
            </VBox>

            <!-- Menu 6: Catering Prasmanan -->
            <VBox spacing="5.0" GridPane.columnIndex="1" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Text text="🎉 Catering Prasmanan" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-fill: #2E7D32;" />
                <Text text="Paket lengkap untuk acara, min. 50 porsi" style="-fx-font-size: 12; -fx-fill: #666666;" />
                <Text text="Rp 45.000/porsi" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-fill: #D35400;" />
                <Button text="Pesan" onAction="#handlePesanPrasmanan" style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="150.0" />
            </VBox>

        </GridPane>
    </VBox>
</AnchorPane>