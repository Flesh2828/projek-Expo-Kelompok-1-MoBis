<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #FFFfff; -fx-padding: 20;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="controller.KonfirmasiBerhasilController">

    <Text style="-fx-font-size: 64;" text="✅" />

    <Text style="-fx-font-size: 28; -fx-font-weight: bold; -fx-fill: black;" text="Konfirmasi Pembayaran Berhasil!" />

    <Text style="-fx-font-size: 14; -fx-fill: #666666;" text="Terima kasih! Admin telah menerima konfirmasi pembayaran Anda." />

    <Text style="-fx-font-size: 14; -fx-fill: #666666;" text="Pembayaran akan diverifikasi dalam 1x24 jam." />

    <Separator />

    <HBox alignment="CENTER" spacing="15.0">
        <Button onAction="#handleLihatRiwayat" style="-fx-background-color: #C35E2A; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;" text="Lihat Riwayat Pesanan" />
    </HBox>

</VBox>
