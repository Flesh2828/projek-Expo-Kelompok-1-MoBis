<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="1200.0" prefWidth="1500.0" spacing="25.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="35.0" left="35.0" right="35.0" top="35.0" />
   </padding>
   <children>
      <VBox spacing="5.0">
         <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2B1B15;" text="Dashboard Pemilik" />
         <Label style="-fx-font-size: 14; -fx-text-fill: #8A7A75;" text="Ringkasan keuangan Sari Rahayu Catering · Juli 2026" />
      </VBox>

      <HBox prefHeight="140.0" spacing="20.0">
         <VBox style="-fx-background-color: fffAf0; -fx-background-radius: 20; -fx-padding: 20;" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: black; -fx-padding: 12 0 2 0;" text="Rp 30 Jt" />
            <Label style="-fx-font-size: 15;" text="Pendapatan (6 Bln)" />
            <Label opacity="0.5" style="-fx-font-size: 15;" text="Bahan baku &amp; operasional" />
         </VBox>

         <VBox style="-fx-background-color: #FFFAF0; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #2B1B15; -fx-padding: 12 0 2 0;" text="Rp 10 Jt" />
            <Label style="-fx-font-size: 15;" text="Pengeluaran (6 Bln)" />
            <Label opacity="0.5" style="-fx-font-size: 15;" text="Bahan baku &amp; operasional" />
         </VBox>

         <VBox style="-fx-background-color: #FFFAF0; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #2B1B15; -fx-padding: 12 0 2 0;" text="Rp 20 Jt" />
            <Label style="-fx-font-size: 15;" text="Laba Bersih (6 Bln)" />
            <Label opacity="0.5" style="-fx-font-size: 15;" text="Margin rata-rata 36%" />
         </VBox>

         <VBox style="-fx-background-color: #FFFAF0; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #2B1B15; -fx-padding: 12 0 2 0;" text="Rp 800.000" />
            <Label style="-fx-font-size: 15;" text="Total Piutang" />
            <Label style="-fx-font-size: 15; -fx-text-fill: #B54D22; -fx-font-weight: bold;" text="2 tagihan lewat jatuh tempo" />
         </VBox>
      </HBox>

      <VBox style="-fx-background-color: #FAFAFA; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
         <Label style="-fx-font-size: 25; -fx-font-weight: bold; -fx-text-fill: #2B1B15;" text="Tren Laba Bersih" />
         <Label style="-fx-font-size: 15; -fx-text-fill: #8A7A75; -fx-padding: 0 0 15 0;" text="Feb - Jul 2026" />
         <Label prefHeight="37.0" prefWidth="147.0" style="-fx-font-size: 16; -fx-text-fill: #6E5E59; -fx-padding: 30 0 0 0;" text="📊 Grafik Laba Bersih" />
      </VBox>
   </children>
</VBox>
