<AnchorPane prefHeight="1328.0" prefWidth="1477.0" style="-fx-background-color: #FfffFE;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.PembayaranController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" layoutX="44.0" layoutY="55.0" prefHeight="1183.0" prefWidth="1404.0" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="AS_NEEDED" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="24.0" AnchorPane.rightAnchor="49.0" AnchorPane.topAnchor="30.0">
        <content>
            <VBox prefHeight="1147.0" prefWidth="1349.0" spacing="15.0">

                <!-- Judul -->
                <Text style="-fx-font-size: 28; -fx-font-weight: bold; -fx-fill: black;" text="Pembayaran" wrappingWidth="171.70703125" />
                <Text style="-fx-font-size: 14; -fx-fill: #666666;" text="Informasi rekening dan upload bukti pembayaran" />

                <Separator />

                <!-- Tagihan Belum Lunas (DINAMIS, diisi dari riwayat pesanan) -->
                <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0" spacing="8.0" style="-fx-background-color: FFFAF0; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-padding: 15;">
                    <Text fx:id="txtJudulTagihan" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-fill: red;" text="Tagihan Belum Lunas">
                        <font>
                            <Font name="System Bold" size="28.0" />
                        </font>
                    </Text>
                    <VBox fx:id="vboxDaftarTagihan" spacing="4.0" />
                    <Text fx:id="txtSisaTagihan" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-fill: red;" text="Total: Rp 0">
                        <font>
                            <Font name="System Bold" size="28.0" />
                        </font>
                        <VBox.margin>
                            <Insets />
                        </VBox.margin>
                    </Text>
                </VBox>

                <!-- Transfer Bank -->
                <Text style="-fx-font-size: 28; -fx-font-weight: bold; -fx-fill: black;" text="Transfer Bank">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Text>

                <GridPane hgap="15" prefHeight="169.0" prefWidth="1389.0" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="33" />
                        <ColumnConstraints percentWidth="33" />
                        <ColumnConstraints percentWidth="33" />
                    </columnConstraints>

                    <!-- BCA -->
                    <VBox spacing="3.0" style="-fx-background-color: #FFFAF0; -fx-border-color: #E0E0E0; -fx-border-radius: 6; -fx-padding: 10; -fx-alignment: center;" GridPane.columnIndex="0">
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="BCA">
                     <font>
                        <Font name="System Bold" size="28.0" />
                     </font>
                  </Text>
                        <Text fill="#f4f0f0" style="-fx-font-size: 23; -fx-fill: #333;" text="1234 5678 90" />
                        <Text style="-fx-font-size: 20; -fx-fill: #666666;" text="a/n Sari Rahayu" />
                        <Button minHeight="0.0" minWidth="0.0" onAction="#handleSalinRekening" prefHeight="42.0" prefWidth="110.0" style="-fx-background-color: #F3F4F6; -fx-text-fill: #333; -fx-font-size: 20;" text="Salin">
                            <VBox.margin>
                                <Insets />
                            </VBox.margin>
                        </Button>
                    </VBox>

                    <!-- BRI -->
                    <VBox spacing="3.0" style="-fx-background-color: #FFFAF0; -fx-border-color: #E0E0E0; -fx-border-radius: 6; -fx-padding: 10; -fx-alignment: center;" GridPane.columnIndex="1">
                        <Text style="-fx-font-size: 28; -fx-font-weight: bold; -fx-fill: black;" text="BRI">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Text>
                        <Text style="-fx-font-size: 23; -fx-fill: #333;" text="0987 6543 21" />
                        <Text style="-fx-font-size: 20; -fx-fill: #666666;" text="a/n Sari Rahayu" />
                        <Button minHeight="0.0" minWidth="0.0" onAction="#handleSalinRekening" prefHeight="42.0" prefWidth="110.0" style="-fx-background-color: #F3F4F6; -fx-text-fill: #333; -fx-font-size: 20;" text="Salin" />
                    </VBox>

                    <!-- Mandiri -->
                    <VBox prefHeight="169.0" prefWidth="475.0" spacing="3.0" style="-fx-background-color: #FFFAF0; -fx-border-color: #E0E0E0; -fx-border-radius: 6; -fx-padding: 10; -fx-alignment: center;" GridPane.columnIndex="2">
                        <Text style="-fx-font-size: 28; -fx-font-weight: bold; -fx-fill: black;" text="Mandiri">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Text>
                        <Text style="-fx-font-size: 23; -fx-fill: #333;" text="1122 3344 55" />
                        <Text style="-fx-font-size: 20; -fx-fill: #666666;" text="a/n Sari Rahayu" />
                        <Button minHeight="0.0" minWidth="0.0" onAction="#handleSalinRekening" prefHeight="42.0" prefWidth="110.0" style="-fx-background-color: #F3F4F6; -fx-text-fill: #333; -fx-font-size: 20;" text="Salin" />
                    </VBox>
                    <rowConstraints>
                        <RowConstraints />
                    </rowConstraints>
                </GridPane>

                <!-- QRIS -->
                <Text style="-fx-font-size: 28; -fx-font-weight: bold; -fx-fill: black;" text="QRIS">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Text>

                <VBox prefHeight="335.0" prefWidth="1324.0" spacing="5.0" style="-fx-background-color: #FFFAF0; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-padding: 15; -fx-alignment: center;">
                    <ImageView fitHeight="557.0" fitWidth="312.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@qris.png" />
                        </image>
                    </ImageView>
                    <Text style="-fx-font-size: 20; -fx-fill: #888888;" text="Scan dengan GoPay, OVO, Dana, atau m-Banking">
                        <VBox.margin>
                            <Insets />
                        </VBox.margin>
                    </Text>
                </VBox>

                <Separator />

                <!-- Tombol Konfirmasi Bayar -->
                <HBox alignment="CENTER_RIGHT">
                    <Button onAction="#handleKonfirmasiBayar" prefHeight="40.0" prefWidth="172.0" style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;" text="Konfirmasi Bayar">
                  <font>
                     <Font size="14.0" />
                  </font></Button>
                </HBox>

            </VBox>
        </content>
    </ScrollPane>
</AnchorPane>
