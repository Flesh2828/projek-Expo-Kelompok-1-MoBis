<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="950.0" prefHeight="600.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.PelangganDashboardController">
    
    <left>
        <VBox spacing="15.0" style="-fx-background-color: #D35400;" prefWidth="220.0">
            <padding>
                <Insets top="30.0" right="15.0" bottom="30.0" left="15.0"/>
            </padding>
            
            <VBox spacing="2.0">
                <Text text="SINARING" style="-fx-font-weight: bold; -fx-font-size: 20; -fx-fill: white;"/>
                <Text text="SARI RAHAYU" style="-fx-font-size: 10; -fx-fill: #F5B041; -fx-font-weight: bold;"/>
            </VBox>
            
            <Separator opacity="0.3"/>
            <Text text="MENU UTAMA" style="-fx-font-size: 11; -fx-fill: #FADBD8; -fx-font-weight: bold;"/>
            
            <Button text="📋 Daftar Menu" onAction="#tampilkanDaftarMenu" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" prefWidth="200.0"/>
            <Button text="➕ Buat Pesanan" onAction="#tampilkanBuatPesanan" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" prefWidth="200.0"/>
            <Button text="🕒 Riwayat Pesanan" onAction="#tampilkanRiwayatPesanan" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" prefWidth="200.0"/>
            <Button text="📅 Langganan" onAction="#tampilkanLangganan" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" prefWidth="200.0"/>
            <Button text="💳 Pembayaran" onAction="#tampilkanPembayaran" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" prefWidth="200.0"/>
            
            <Region VBox.vgrow="ALWAYS" />
            
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Text text="👤" style="-fx-font-size: 18; -fx-fill: white;"/>
                <VBox>
                    <Text fx:id="txtNamaUser" text="Pelanggan" style="-fx-font-weight: bold; -fx-fill: white;"/>
                    <Text text="Pelanggan" style="-fx-font-size: 11; -fx-fill: #E67E22;"/>
                </VBox>
            </HBox>
            
            <Button text="🚪 Keluar" onAction="#handleLogout" style="-fx-background-color: #C0392B; -fx-text-fill: white;" prefWidth="200.0"/>
        </VBox>
    </left>
    
    <center>
        <AnchorPane fx:id="paneKontenTengah" style="-fx-background-color: #FDFEFE;"/>
    </center>
    
</BorderPane>