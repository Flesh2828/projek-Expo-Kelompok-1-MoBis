<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="600.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.PelangganDashboardController">
    
    <left>
        <VBox prefWidth="380.0" spacing="15.0" style="-fx-background-color: #B8541F;">
            <padding>
                <Insets bottom="30.0" left="15.0" right="15.0" top="30.0" />
            </padding>
            
            <VBox spacing="2.0">
                <Text style="-fx-font-weight: bold; -fx-font-size: 50; -fx-fill: white;" text="SINARING" />
                <Text style="-fx-font-size: 30; -fx-fill: white; -fx-font-weight: bold;" text="SARI RAHAYU" />
            </VBox>
            
            <Separator opacity="0.3" />
            <Text style="-fx-font-size: 25; -fx-fill: #FADBD8; -fx-font-weight: bold;" text="MENU UTAMA" />
            
            <Button onAction="#tampilkanDaftarMenu" prefWidth="500.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" text="Daftar Menu">
            <font>
               <Font name="Calibri" size="25.0" />
            </font></Button>
            <Button onAction="#tampilkanBuatPesanan" prefWidth="500.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" text="Buat Pesanan">
            <font>
               <Font name="Calibri" size="25.0" />
            </font></Button>
            <Button onAction="#tampilkanRiwayatPesanan" prefWidth="500.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" text="Riwayat Pesanan">
            <font>
               <Font name="Calibri" size="25.0" />
            </font></Button>
            <Button onAction="#tampilkanLangganan" prefWidth="500.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" text="Langganan">
            <font>
               <Font name="Calibri" size="25.0" />
            </font></Button>
            <Button onAction="#tampilkanPembayaran" prefWidth="500.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left;" text="Pembayaran">
            <font>
               <Font name="Calibri" size="25.0" />
            </font></Button>
            
            <Region VBox.vgrow="ALWAYS" />
            
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Text style="-fx-font-size: 18; -fx-fill: white;" text="👤" />
                <VBox>
                    <Text fx:id="txtNamaUser" style="-fx-font-weight: bold; -fx-fill: white;" text="Pelanggan" />
                    <Text style="-fx-font-size: 11; -fx-fill: #E67E22;" text="Pelanggan" />
                </VBox>
            </HBox>
            
            <Button onAction="#handleLogout" prefWidth="200.0" style="-fx-background-color: #C0392B; -fx-text-fill: white;" text="🚪 Keluar" />
        </VBox>
    </left>
    
    <center>
        <AnchorPane fx:id="paneKontenTengah" style="-fx-background-color: #FDFEFE;" />
    </center>
    
</BorderPane>
