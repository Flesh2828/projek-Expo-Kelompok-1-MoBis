<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="20.0" prefWidth="600.0" prefHeight="400.0" style="-fx-background-color: #ebf5fb;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.PelangganDashboardController">
    <Text text="PANEL PELANGGAN - SINARING" style="-fx-font-weight: bold; -fx-font-size: 22; -fx-fill: #2980b9;"/>
    <Label text="Selamat Datang, Pelanggan Setia! Silakan kelola pesanan katering Anda di sini." style="-fx-font-size: 14;"/>
    
    <HBox alignment="CENTER" spacing="10.0">
        <Button text="Pesan Katering Baru"/>
        <Button text="Riwayat Pesanan"/>
    </HBox>

    <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
</VBox>